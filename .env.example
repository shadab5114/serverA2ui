# ===== LLM provider selection =====
# "openai" (default) or "anthropic"
LLM_PROVIDER=openai

# ----- OpenAI -----
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ----- Anthropic (for later) -----
# ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8

# ===== MCP server (catalog source) =====
MCP_URL=http://localhost:3939/mcp
MCP_CATALOG_TOOL=

# ===== HTTP server =====
PORT=8080
